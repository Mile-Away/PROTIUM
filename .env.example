# Django settings for security and debugging
# SECRET_KEY is used for Django encryption and security-related operations
SECRET_KEY=your-secret-key

# Enable debug mode for development, should be set to False in production
DEBUG=True

# Allowed hosts for the Django application
# List of hostnames and IP addresses allowed to connect to the Django app
ALLOWED_HOSTS=your-allowed-hosts

# CORS settings for allowing specific origins
# List of origins allowed to make cross-origin requests
CORS_ORIGIN_WHITELIST=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:4000,http://127.0.0.1:3003,http://web:3000,http://workflow:3003,http://docs:4000

# CSRF trusted origins
# List of origins trusted for CSRF protection
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:4000,http://127.0.0.1:3003,http://web:3000,http://workflow:3003,http://docs:4000

# JWT settings for token lifetime
# Lifetime of access tokens in minutes
ACCESS_TOKEN_LIFETIME=30

# Lifetime of refresh tokens in days
REFRESH_TOKEN_LIFETIME=14

# Database configuration
# Database engine
DATABASE_ENGINE=django.db.backends.postgresql

# Database hostname
DATABASE_HOST=db

# Database name
DATABASE_NAME=your-database-name

# Database username
DATABASE_USER=your-database-user

# Database password
DATABASE_PASSWORD=your-database-password

# Database port
DATABASE_PORT=5432

# Elasticsearch configuration
# Elasticsearch password
ELASTICSEARCH_PASSWORD=your-elasticsearch-password

# Elasticsearch username
ELASTICSEARCH_USERNAME=your-elasticsearch-username

# Elasticsearch host address
ELASTICSEARCH_HOST=http://elasticsearch:9200

# Email configuration
# Email server hostname
EMAIL_HOST=your-email-host

# Email server username
EMAIL_HOST_USER=your-email-user

# Email server password
EMAIL_HOST_PASSWORD=your-email-password

# JWT cookie settings
# Domain for JWT cookies
JWT_COOKIE_DOMAIN=your-jwt-cookie-domain

# SameSite attribute for JWT cookies
JWT_COOKIE_SAMESITE=Lax

# Whether JWT cookies should only be sent over HTTPS
JWT_COOKIE_SECURE=False
